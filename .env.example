# Copy to .env.local and fill in real values. .env.local is gitignored — NEVER commit real keys.

# --- Database (PostgreSQL + pgvector) ---
POSTGRES_USER=oxot
POSTGRES_PASSWORD=change-me
POSTGRES_DB=oxot
DATABASE_URL=postgres://oxot:change-me@db:5432/oxot

# --- Ollama (local, in-cluster) ---
OLLAMA_HOST=http://ollama:11434
OLLAMA_EMBED_MODEL=qwen3-embedding:4b   # native 2560-dim
# Authoritative dimension is 1536 (decision 2026-07-14, migration 035_embed_dim_1536.sql).
# qwen3-embedding:4b emits 2560 natively; the shared fitDim helper truncates to the
# first 1536 dims and L2-renormalizes (Matryoshka/MRL truncation), applied identically
# in src/lib/embeddings.ts (query) and scripts/ingest.mjs (index). MUST match the
# pgvector column dimension exactly — changing this value requires a full re-ingest.
EMBED_DIM=1536
OLLAMA_CHAT_MODEL=qwen3.5:9b            # local generation default (installed on this box)

# --- OpenRouter (generation fallback) ---
OPENROUTER_API_KEY=
OPENROUTER_MODEL=openai/gpt-4o-mini     # fallback tier (change as desired)

# --- Valyu (research / deep-search) ---
VALYU_API_KEY=

# --- App ---
NODE_ENV=development
DEFAULT_LOCALE=en
SUPPORTED_LOCALES=nl,en

# --- Admin auth ---
AUTH_SECRET=change-me-to-a-long-random-string

# --- Default admin (private / dev deployment) ---
# A default admin is auto-created ONLY if none exists yet — on `docker compose up`
# (local) and on the Railway pre-deploy step. No password change is required.
# To use different credentials, set these before the first deploy (Railway variables
# or .env.local); once an admin exists these are ignored.
ADMIN_EMAIL=admin@oxot.local
ADMIN_PASSWORD=OxotDev!2026

# --- Settings encryption (AES-256-GCM for the admin-stored OpenRouter key) ---
# Optional; falls back to AUTH_SECRET if unset. Rotating it invalidates any
# encrypted key already saved via the admin panel (re-enter it in AI & Models).
SETTINGS_SECRET=

# --- Cron (scheduled-newsletter sends + LinkedIn token-expiry check) ---
# Required to enable POST/GET /api/cron. Point a Railway Cron job (or any
# scheduler) at this endpoint every 5 minutes with header `x-cron-secret` or
# `?key=` set to this value. Leave unset to keep the endpoint disabled.
CRON_SECRET=
