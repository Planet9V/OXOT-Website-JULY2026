# Copy to .env.local and fill in real values. .env.local is gitignored — NEVER commit real keys.

# --- Database (PostgreSQL + pgvector) ---
POSTGRES_USER=oxot
POSTGRES_PASSWORD=change-me
POSTGRES_DB=oxot
DATABASE_URL=postgres://oxot:change-me@db:5432/oxot

# --- Ollama (local, in-cluster) ---
OLLAMA_HOST=http://ollama:11434
OLLAMA_EMBED_MODEL=qwen3-embedding:4b   # native 2560-dim
EMBED_DIM=2560                          # MUST match your embedding model's output length
OLLAMA_CHAT_MODEL=qwen3.5:9b            # local generation default (installed on this box)

# --- OpenRouter (generation fallback) ---
OPENROUTER_API_KEY=
OPENROUTER_MODEL=openai/gpt-4o-mini     # fallback tier (change as desired)

# --- Valyu (research / deep-search) ---
VALYU_API_KEY=

# --- App ---
NODE_ENV=development
DEFAULT_LOCALE=en
SUPPORTED_LOCALES=nl,en

# --- Admin auth ---
AUTH_SECRET=change-me-to-a-long-random-string

# --- Default admin (LOCAL dev only) ---
# On `docker compose up`, a default admin is auto-created ONLY if none exists yet.
# Change the password after first login. Do NOT rely on these for a public deploy —
# there, create an admin with your own password via scripts/create-admin.mjs.
ADMIN_EMAIL=admin@oxot.local
ADMIN_PASSWORD=changeme

# --- Settings encryption (AES-256-GCM for the admin-stored OpenRouter key) ---
# Optional; falls back to AUTH_SECRET if unset. Rotating it invalidates any
# encrypted key already saved via the admin panel (re-enter it in AI & Models).
SETTINGS_SECRET=
